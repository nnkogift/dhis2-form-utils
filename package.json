{
  "name": "dhis2-form-utils",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Composable, design-system-agnostic form library for DHIS2 data entry in React",
  "scripts": {
    "build": "pnpm --filter '@dhis2-form-utils/*' run build && pnpm --filter storybook build",
    "test": "vitest run && pnpm --filter storybook test",
    "test:watch": "vitest",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "typecheck": "pnpm --filter '@dhis2-form-utils/*' run typecheck && pnpm --filter playground run typecheck",
    "format": "prettier --write .",
    "storybook": "pnpm --filter storybook dev",
    "playground": "pnpm --filter playground dev"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fallow": "^2.76.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
