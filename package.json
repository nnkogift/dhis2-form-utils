{
    "name": "dhis2-form-utils",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "description": "Composable, design-system-agnostic form library for DHIS2 data entry in React",
    "scripts": {
        "build": "pnpm --filter '@dhis2-form-utils/*' run --if-present build && pnpm --filter storybook build",
        "test:unit": "vitest run",
        "test:storybook": "pnpm --filter storybook test",
        "test": "concurrently -c 'green,blue' -n 'unit,storybook'  --kill-others-on-fail 'pnpm run test:unit' 'pnpm run test:storybook'",
        "test:watch": "vitest",
        "lint": "eslint . && prettier --check .",
        "codeq": "fallow audit",
        "lint:fix": "eslint . --fix && prettier --write .",
        "typecheck": "pnpm -r --if-present run typecheck",
        "format": "prettier --write .",
        "storybook": "pnpm --filter storybook dev",
        "playground": "pnpm --filter playground dev",
        "precommit": "lint-staged && node scripts/typecheck-staged.mjs",
        "prepare": "husky",
        "clean": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +"
    },
    "lint-staged": {
        "*.{ts,tsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{js,mjs,cjs,json,md,yml,yaml}": "prettier --fix"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@testing-library/react": "^16.3.2",
        "@types/react": "^18.3.29",
        "@types/react-dom": "^18.3.7",
        "@vitest/coverage-v8": "^4.1.7",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "fallow": "^2.76.0",
        "husky": "^9.1.7",
        "jsdom": "^29.1.1",
        "lint-staged": "^17.0.5",
        "prettier": "^3.8.3",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.4",
        "vitest": "^4.1.7"
    },
    "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
    "dependencies": {
        "concurrently": "^10.0.0"
    }
}
