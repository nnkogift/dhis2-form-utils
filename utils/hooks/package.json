{
    "name": "@dhis2-form-utils/hooks",
    "version": "0.0.0",
    "description": "Headless React hooks for DHIS2 form lifecycle",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "dependencies": {
        "@dhis2-form-utils/metadata": "workspace:*",
        "@dhis2-form-utils/rules": "workspace:*"
    },
    "peerDependencies": {
        "@dhis2/app-runtime": ">=3.0.0",
        "@hookform/resolvers": ">=3.0.0",
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0",
        "react-hook-form": ">=7.0.0",
        "zod": ">=3.0.0"
    },
    "devDependencies": {
        "@dhis2/app-runtime": "^3.17.0",
        "@dhis2/data-engine": "^3.17.0",
        "@dhis2-form-utils/config": "workspace:*",
        "@hookform/resolvers": "^5.2.2",
        "@testing-library/react": "^16.3.2",
        "@types/react": "^18.3.29",
        "@types/react-dom": "^18.3.7",
        "jsdom": "^29.1.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-hook-form": "^7.76.0",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vitest": "^4.1.7",
        "zod": "^3.25.76"
    }
}
