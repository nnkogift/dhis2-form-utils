{
    "name": "@dhis2-form-utils/metadata",
    "version": "0.0.0",
    "description": "Convert DHIS2 metadata into Zod schemas for React Hook Form",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "dependencies": {
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@dhis2-form-utils/config": "workspace:*",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vitest": "^4.1.7"
    }
}
