{
    "name": "@dhis2-form-utils/dhis2-ui",
    "version": "0.0.0",
    "description": "DHIS2 UI field components and forms for dhis2-form-utils",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "typecheck": "tsc --noEmit",
        "test": "vitest run"
    },
    "dependencies": {
        "@dhis2-form-utils/hooks": "workspace:*"
    },
    "peerDependencies": {
        "@dhis2/ui": ">=9.0.0",
        "react": ">=18.0.0",
        "react-dom": ">=18.0.0",
        "react-hook-form": ">=7.0.0"
    },
    "devDependencies": {
        "@dhis2-form-utils/config": "workspace:*",
        "@dhis2/ui": "^10.15.1",
        "@types/react": "^18.3.29",
        "@types/react-dom": "^18.3.7",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-hook-form": "^7.76.0",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3",
        "vitest": "^4.1.7"
    }
}
